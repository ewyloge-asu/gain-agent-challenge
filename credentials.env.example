# Copy this file to `credentials.env` (same directory) and fill in your keys.
# credentials.env is gitignored and must never be committed.
# The connector auto-loads it; values here do NOT override an already-set env var.

# Congress.gov API key -- free, instant. Sign up: https://api.congress.gov/sign-up/
# Used by: connector.py legislation  (the pay -> say -> ACT leg)
CONGRESS_GOV_API_KEY=

# FEC / api.open.fec.gov key -- free. Sign up: https://api.open.fec.gov/developers/
# DEMO_KEY works but is heavily rate-limited; get a real key for actual runs.
# Used by: connector.py fec  (campaign-finance ground-truthing)
FEC_API_KEY=
