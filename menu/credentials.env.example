# Bundle API keys — copy to `credentials.env` (gitignored) or run `python3 setup_keys.py`.
# ALL OPTIONAL. Every skill runs at Tier 0 (offline, no keys) from shipped snapshots.
# Keys only unlock richer enrichment tiers; they never gate the core findings.

# Congress.gov — sponsored bills + policy areas (the "act" leg).
# Get one free: https://api.congress.gov/sign-up/
CONGRESS_GOV_API_KEY=

# FEC (OpenFEC) — campaign-finance denominator. An api.data.gov key also works.
# Get one free: https://api.open.fec.gov/developers/
FEC_API_KEY=

# api.data.gov — keyed data.gov catalog (v4) + many federal APIs (one key, many services).
# Get one free: https://api.data.gov/signup/
DATA_GOV_API_KEY=

# CourtListener / RECAP — court dockets & filings for legal cross-checks.
# Get one free: https://www.courtlistener.com/help/api/rest/
COURTLISTENER_API_TOKEN=
